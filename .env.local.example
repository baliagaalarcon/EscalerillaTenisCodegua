# ─────────────────────────────────────────────────────────
# SUPABASE
# Copia este archivo a .env.local y completa los valores.
# Los encuentras en: Supabase Dashboard → Settings → API
# ─────────────────────────────────────────────────────────

# URL pública del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co

# Clave anónima (pública, va en el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# Clave de servicio (PRIVADA — solo en servidor, nunca en cliente)
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# ─────────────────────────────────────────────────────────
# WEB PUSH NOTIFICATIONS (PWA)
# Generarlas con: npx web-push generate-vapid-keys
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=TU_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=TU_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@clubcodegua.cl

# ─────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLUB_NOMBRE=Club de Tenis Codegua
